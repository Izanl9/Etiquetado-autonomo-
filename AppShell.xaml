<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="EtiquetadoAuto.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:EtiquetadoAuto.Pages"
       Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#2196F3"
       Shell.TabBarUnselectedColor="#757575">

    <TabBar>
        <Tab Title="Escáner">
            <ShellContent ContentTemplate="{DataTemplate pages:ScannerPage}" />
        </Tab>
        <Tab Title="Inventario">
            <ShellContent ContentTemplate="{DataTemplate pages:InventoryPage}" />
        </Tab>
    </TabBar>
</Shell>
