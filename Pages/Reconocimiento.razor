@page "/reconocimiento"
@using Microsoft.Maui.Media
@using EtiquetadoAuto.Models
@inject IJSRuntime JSRuntime

<div class="container text-center">
    <h3>Escáner de Productos</h3>
    <hr />

    <div class="d-grid gap-2">
        <button class="btn btn-primary btn-lg" @onclick="TomarFoto">
            <i class="oi oi-camera"></i> Abrir Cámara
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info mt-3">
            @statusMessage
        </div>
    }
</div>

@code {
    private string statusMessage = "Listo para escanear";

    private async Task TomarFoto()
    {
        try
        {
            if (MediaPicker.Default.IsCaptureSupported)
            {
                statusMessage = "Abriendo cámara nativa...";
                
                // Captura la foto usando el hardware del móvil
                FileResult photo = await MediaPicker.Default.CapturePhotoAsync();
                
                if (photo != null)
                {
                    statusMessage = $"Foto capturada: {photo.FileName}. Procesando...";
                    
                    // Aquí puedes leer el stream de la imagen si necesitas enviarlo a una IA
                    using var stream = await photo.OpenReadAsync();
                    
                    // Ejemplo: var bytes = new byte[stream.Length];
                    // await stream.ReadAsync(bytes);
                }
                else
                {
                    statusMessage = "Captura cancelada.";
                }
            }
            else
            {
                statusMessage = "La cámara no está disponible en este dispositivo.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("alert", "Error al abrir la cámara: " + ex.Message);
        }
    }
}