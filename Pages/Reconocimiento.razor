@page "/reconocimiento"
@using System.IO

<div class="container-fluid text-center mt-4">
    <h3 class="text-primary mb-4"> Visión Artificial</h3>
    <p class="text-muted">Apunta con la cámara al producto para identificarlo.</p>

    <button class="btn btn-primary btn-lg w-100 shadow fw-bold mb-3" @onclick="TomarFoto">
         ABRIR CÁMARA
    </button>

    @if (!string.IsNullOrEmpty(FotoBase64))
    {
        <div class="card p-3 shadow-sm mt-3 border-success">
            <h5 class="text-success mb-3">Foto capturada correctamente</h5>
            
            <img src="@FotoBase64" class="img-fluid rounded shadow-sm mb-3" style="max-height: 400px; object-fit: contain;" />
            
            <button class="btn btn-success btn-lg w-100 fw-bold" @onclick="AnalizarConIA">
                 ANALIZAR PRODUCTO (IA)
            </button>
        </div>
    }
</div>

@code {
    string FotoBase64 = "";

    async Task TomarFoto()
    {
        try
        {
            // Esta línea mágica llama a la cámara de Android, iOS o Windows
            if (MediaPicker.Default.IsCaptureSupported)
            {
                var photo = await MediaPicker.Default.CapturePhotoAsync();

                if (photo != null)
                {
                    // Convertimos la foto a un formato visualizable en la web (Base64)
                    using var stream = await photo.OpenReadAsync();
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    var bytes = memoryStream.ToArray();
                    
                    FotoBase64 = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"El usuario canceló o hubo un error: {ex.Message}");
        }
    }

    void AnalizarConIA()
    {
        // 🚧 PRÓXIMO PASO: Aquí enviaremos la foto a nuestro motor de IA
        Console.WriteLine("Enviando foto a la nube para su análisis...");
    }
}
